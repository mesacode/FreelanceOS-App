model Customer {
  id            String         @id @default(cuid())
  fullName      String
  email         String?
  phone         String?
  company       String?
  notes         String?
  lastContactAt DateTime?
  status        CustomerStatus @default(LEAD)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  projects  Project[]
  reminders Reminder[]
  incomes   Income[]
  expenses  Expense[]
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  price       Float?
  status      ProjectStatus @default(PENDING)
  startDate   DateTime?
  dueDate     DateTime?
  customerId  String
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  incomes     Income[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Income {
  id         String    @id @default(cuid())
  title      String
  amount     Float
  date       DateTime  @default(now())
  note       String?
  projectId  String?
  customerId String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
}

model Expense {
  id         String    @id @default(cuid())
  title      String
  amount     Float
  category   String?
  date       DateTime  @default(now())
  note       String?
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
}

model Reminder {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime
  isCompleted Boolean   @default(false)
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
}

model WhatsappTemplate {
  id        String   @id @default(cuid())
  name      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

enum CustomerStatus {
  LEAD
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}
