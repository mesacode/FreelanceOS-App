{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "strict": true,
    "noEmit": true,
    "isolatedModules": true,

    "jsx": "react-jsx",

    "types": ["vite/client"]
  },
  "include": ["src", "shared/**/*.ts"]
}
