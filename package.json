{
  "name": "freelanceos",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite --strictPort --port 5173\" \"tsc -p electron/tsconfig.json --watch\" \"wait-on tcp:5173 && set ELECTRON_RUN_AS_NODE=&& electron .\"",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "start": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "electron": "^36.0.0",
    "postcss": "^8.4.49",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
